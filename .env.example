# Copy to .env and fill in. Only VITE_-prefixed vars reach the browser.
# The Supabase anon key is public and RLS-respecting — safe in the client.
# NEVER put the Supabase service-role key here or anywhere in the repo.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_USDA_API_KEY=
VITE_TMDB_API_KEY=
VITE_GOOGLE_BOOKS_API_KEY=   # optional, raises Google Books quota

# Optional access allowlist: comma-separated emails permitted to use the app. Any signed-in Google
# account is rejected (and signed out) unless its email is listed. Leave blank for no restriction.
# Example: VITE_ALLOWED_EMAILS=you@gmail.com, partner@gmail.com
VITE_ALLOWED_EMAILS=
