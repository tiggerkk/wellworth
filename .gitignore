# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
dev-dist
coverage
*.local

# Env — never commit secrets. .env.example is the documented template.
.env
.env.*
!.env.example

# Net Worth — real private balances must never be committed. The sanitized
# templates/networth-seed-template.csv is the only Net Worth CSV that should be tracked.
*-filled.csv
*.local.csv
networth-*.csv
!templates/networth-seed-template.csv

# Shows — real watch-history import lists must never be committed. Only the
# sanitized templates/shows-import-template.csv is tracked.
shows-import*.csv
!templates/shows-import-template.csv

# Books — real read-history import lists must never be committed. Only the
# sanitized templates/books-import-template.csv is tracked.
books-import*.csv
!templates/books-import-template.csv

# Quotes — real personal quote collections must never be committed. Only the
# sanitized templates/quotes-import-template.csv is tracked.
quotes-import*.csv
quotes-seed-local.csv
!templates/quotes-import-template.csv

# Medical — real lab results & report PDFs (contain name / HKID / DOB) must never be
# committed. Only templates/medical-import.schema.json, medical-extraction-prompt.md,
# and the sanitized templates/medical-import-template.json are tracked.
medical-import-20*.json
templates/*.pdf

# Travel — real expense sheets must never be committed. Only the sanitized
# templates/travel-expenses-template.csv is tracked.
travel-expenses*.csv
!templates/travel-expenses-template.csv

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
